# Copy this file to secrets.yaml on the HA Green only.
# secrets.yaml MUST NOT be committed to git (see .gitignore).
# Reference values from YAML with: !secret <name>

# Example entries — replace with real values inside secrets.yaml:
# latitude: 0.0000
# longitude: 0.0000
# elevation: 0
# notify_email: you@example.com
# mqtt_password: change-me
